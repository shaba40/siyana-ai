<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <meta
        name="description"
        content="Siyana AI offline industrial-maintenance assistant"
    >

    <title>Siyana AI</title>

    <link rel="stylesheet" href="/static/styles.css">
</head>

<body>
    <header class="topbar">
        <div class="brand">
            <div class="brand-mark">S</div>

            <div>
                <h1>Siyana AI</h1>

                <p id="brandSubtitle">
                    Offline industrial-maintenance support
                </p>
            </div>
        </div>

        <div
            id="statusBadge"
            class="status-badge status-checking"
        >
            <span class="status-dot"></span>
            <span id="statusText">Checking local model...</span>
        </div>
    </header>

    <main class="page-layout">
        <section class="hero-panel">
            <div class="hero-content">
                <span class="eyebrow">
                    LOCAL • MULTILINGUAL • PRIVATE
                </span>

                <h2 id="heroTitle">
                    Safer preliminary maintenance guidance,
                    completely offline.
                </h2>

                <p id="heroDescription">
                    Describe an industrial-machine symptom.
                    Siyana AI uses the local Qwen3-4B model
                    to produce structured, safety-focused
                    preliminary guidance.
                </p>
            </div>

            <div class="privacy-card">
                <div class="privacy-icon">⌂</div>

                <div>
                    <strong id="privacyTitle">
                        Local processing
                    </strong>

                    <p id="privacyText">
                        Questions and answers remain on this
                        computer. No cloud inference API is used.
                    </p>
                </div>
            </div>
        </section>

        <section class="workspace">
            <form
                id="chatForm"
                class="question-panel"
            >
                <div class="panel-heading">
                    <div>
                        <h3 id="questionHeading">
                            Describe the situation
                        </h3>

                        <p id="questionHelp">
                            Add the available machine information.
                            Do not enter secrets or personal data.
                        </p>
                    </div>

                    <label class="language-control">
                        <span id="languageLabel">Language</span>

                        <select id="language" name="language">
                            <option value="en">English</option>
                            <option value="fr">Français</option>
                            <option value="ar">العربية</option>
                        </select>
                    </label>
                </div>

                <div class="field-grid">
                    <label class="field">
                        <span id="machineNameLabel">
                            Machine or equipment
                        </span>

                        <input
                            id="machineName"
                            name="machineName"
                            type="text"
                            maxlength="200"
                            placeholder="Example: Pneumatic press"
                        >
                    </label>

                    <label class="field">
                        <span id="machineModelLabel">
                            Model, if known
                        </span>

                        <input
                            id="machineModel"
                            name="machineModel"
                            type="text"
                            maxlength="200"
                            placeholder="Example: PX-200"
                        >
                    </label>
                </div>

                <label class="field">
                    <span id="questionLabel">
                        Symptom or question
                    </span>

                    <textarea
                        id="question"
                        name="question"
                        required
                        minlength="3"
                        maxlength="4000"
                        rows="7"
                        placeholder="Example: The pneumatic cylinder has become slow in both directions."
                    ></textarea>

                    <span
                        id="characterCount"
                        class="character-count"
                    >
                        0 / 4000
                    </span>
                </label>

                <label class="field">
                    <span id="contextLabel">
                        Additional context, if available
                    </span>

                    <textarea
                        id="additionalContext"
                        name="additionalContext"
                        maxlength="3000"
                        rows="4"
                        placeholder="Operating load, alarm text, recent changes, observations..."
                    ></textarea>
                </label>

                <div class="form-footer">
                    <div class="safety-reminder">
                        <strong id="safetyReminderTitle">
                            Safety reminder
                        </strong>

                        <span id="safetyReminderText">
                            Stop and isolate hazardous energy
                            before inspection or maintenance.
                        </span>
                    </div>

                    <button
                        id="submitButton"
                        class="primary-button"
                        type="submit"
                    >
                        <span id="submitButtonText">
                            Ask Siyana AI
                        </span>

                        <span
                            id="buttonSpinner"
                            class="button-spinner"
                            hidden
                        ></span>
                    </button>
                </div>
            </form>

            <section
                id="answerPanel"
                class="answer-panel"
                aria-live="polite"
            >
                <div
                    id="emptyState"
                    class="empty-state"
                >
                    <div class="empty-icon">◎</div>

                    <h3 id="emptyTitle">
                        The local assistant is ready
                    </h3>

                    <p id="emptyText">
                        Submit an industrial-maintenance question
                        to view a structured response.
                    </p>
                </div>

                <div
                    id="answerContent"
                    class="answer-content"
                    hidden
                >
                    <div class="answer-header">
                        <div>
                            <span class="answer-label">
                                SIYANA AI
                            </span>

                            <h3 id="answerTitle">
                                Preliminary guidance
                            </h3>
                        </div>

                        <button
                            id="copyButton"
                            class="secondary-button"
                            type="button"
                        >
                            Copy
                        </button>
                    </div>

                    <div
                        id="answerText"
                        class="answer-text"
                    ></div>

                    <div class="answer-metadata">
                        <span id="modelMetadata"></span>
                        <span id="durationMetadata"></span>
                        <span id="offlineMetadata"></span>
                    </div>

                    <div class="answer-safety">
                        <strong id="answerSafetyTitle">
                            Important
                        </strong>

                        <p id="answerSafetyNotice"></p>
                    </div>
                </div>

                <div
                    id="errorPanel"
                    class="error-panel"
                    hidden
                >
                    <strong id="errorTitle">
                        Unable to generate a response
                    </strong>

                    <p id="errorText"></p>
                </div>
            </section>
        </section>

        <section class="limitations-panel">
            <h3 id="limitationsTitle">
                Current prototype capabilities
            </h3>

            <div class="limitations-grid">
                <article>
                    <strong id="capabilityOneTitle">
                        Available now
                    </strong>

                    <p id="capabilityOneText">
                        Local English, French and Arabic
                        maintenance guidance.
                    </p>
                </article>

                <article>
                    <strong id="capabilityTwoTitle">
                        Safety focused
                    </strong>

                    <p id="capabilityTwoText">
                        Refuses guard bypasses and energized
                        maintenance instructions.
                    </p>
                </article>

                <article>
                    <strong id="capabilityThreeTitle">
                        Coming next
                    </strong>

                    <p id="capabilityThreeText">
                        Local machine-manual import, search
                        and citations.
                    </p>
                </article>
            </div>
        </section>
    </main>

    <footer>
        <p>
            Siyana AI • Offline industrial-maintenance
            prototype • Qwen3-4B Q4_K_M
        </p>
    </footer>

    <script src="/static/app.js"></script>
</body>
</html>
